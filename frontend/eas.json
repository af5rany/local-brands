{
  "cli": {
    "version": ">= 18.4.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "EXPO_PUBLIC_API_URL": "http://192.168.1.11:5000"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://local-brands-production-0df0.up.railway.app",
        "EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID": "3176566169-a05r5prfmjqfg9dj3ususlj7bu8qichl.apps.googleusercontent.com",
        "EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID": "3176566169-2hod2vokk278ra01ejlls4chh93pah46.apps.googleusercontent.com",
        "EXPO_PUBLIC_GOOGLE_IOS_REVERSE_SCHEME": "com.googleusercontent.apps.3176566169-2hod2vokk278ra01ejlls4chh93pah46",
        "EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID": "3176566169-rqvvg3rjuirbl63plaq7upsg1jrsmh0o.apps.googleusercontent.com",
        "EXPO_PUBLIC_FACEBOOK_APP_ID": "2413827082417241"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "preview-simulator": {
      "extends": "preview",
      "ios": {
        "simulator": true
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://local-brands-production-0df0.up.railway.app",
        "EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID": "3176566169-a05r5prfmjqfg9dj3ususlj7bu8qichl.apps.googleusercontent.com",
        "EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID": "3176566169-2hod2vokk278ra01ejlls4chh93pah46.apps.googleusercontent.com",
        "EXPO_PUBLIC_GOOGLE_IOS_REVERSE_SCHEME": "com.googleusercontent.apps.3176566169-2hod2vokk278ra01ejlls4chh93pah46",
        "EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID": "3176566169-rqvvg3rjuirbl63plaq7upsg1jrsmh0o.apps.googleusercontent.com",
        "EXPO_PUBLIC_FACEBOOK_APP_ID": "2413827082417241"
      },
      "ios": {
        "distribution": "store",
        "credentialsSource": "remote"
      },
      "android": {
        "buildType": "app-bundle",
        "credentialsSource": "remote"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "YOUR_APPLE_ID@example.com",
        "ascAppId": "YOUR_ASC_APP_ID",
        "appleTeamId": "YOUR_APPLE_TEAM_ID"
      },
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "internal"
      }
    }
  }
}
